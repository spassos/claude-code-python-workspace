# ============================================================
# Environment variables template
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ── Claude / Anthropic API ────────────────────────────────────
ANTHROPIC_API_KEY=                  # sk-ant-...

# ── Google Cloud Platform ─────────────────────────────────────
GCP_PROJECT_ID=                     # my-project-123456
GCP_REGION=us-central1              # Cloud Run region
GCP_SERVICE_NAME=                   # Cloud Run service name (e.g. my-app)

# ── Application ───────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL
PORT=8080                           # Port to listen on (Cloud Run injects this)

# ── Database (if applicable) ──────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# ── External APIs (add as needed) ─────────────────────────────
# SOME_API_KEY=
# SOME_API_BASE_URL=https://api.example.com
